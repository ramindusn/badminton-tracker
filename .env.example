# Supabase project credentials.
# Copy to `.env.local` (git-ignored) and fill in from your Supabase project:
#   Dashboard → Project Settings → API
#
# The anon/public key is designed to ship in the client bundle — Row Level
# Security is the real access guard, not key secrecy.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
